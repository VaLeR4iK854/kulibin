---
---

<section class="relative pt-36 lg:pt-44 pb-24 lg:pb-32 overflow-hidden">
  <div class="absolute inset-0 grid-bg opacity-60 pointer-events-none"></div>

  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>

  <div class="relative mx-auto max-w-[1400px] px-6 lg:px-10">

    <div class="flex items-center gap-3 mb-12 reveal">
      <div class="h-px w-10 bg-accent/60"></div>
      <span class="label-accent">ДНЕВНИК НАНО-ФЕРМЫ / ВЫПУСК 01</span>
    </div>

    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-10">
        <h1 class="display text-[clamp(44px,7.6vw,128px)] !leading-[1.02] reveal" style="--reveal-delay: 100ms">
          <span class="block text-text">Растим еду</span>
          <span class="block">
            <span class="text-text-muted">как </span>
            <span class="text-accent">технологию</span>
            <span class="text-text">.</span>
          </span>
        </h1>
      </div>
    </div>

    <div class="mt-16 lg:mt-20 grid grid-cols-12 gap-6 lg:gap-10 items-end">
      <div class="col-span-12 lg:col-span-6 reveal" style="--reveal-delay: 250ms">
        <p class="text-[18px] lg:text-[20px] leading-[1.5] text-text-dim max-w-[52ch]">
          Дневник инженера, который выращивает картошку и клубнику дома.
          Гидропоника, капельный полив, замеры, расчёты. Не как бабушка, не по привычке —
          по протоколу с цифрами на руках.
        </p>
      </div>

      <div class="col-span-12 lg:col-span-6 flex flex-wrap items-center gap-4 lg:justify-end reveal" style="--reveal-delay: 400ms">
        <a
          href="#channels"
          class="group inline-flex items-center gap-3 bg-accent text-bg px-6 h-12 font-mono text-[12px] tracking-[0.18em] uppercase font-medium hover:bg-signal transition-colors"
        >
          <span class="signal-dot !bg-bg !shadow-none"></span>
          Подписаться
          <span class="ml-1 transition-transform group-hover:translate-x-1">→</span>
        </a>
        <a
          href="#manifesto"
          class="inline-flex items-center gap-3 px-6 h-12 font-mono text-[12px] tracking-[0.18em] uppercase text-text border border-border-strong hover:border-accent/60 hover:text-accent transition-colors"
        >
          Что внутри
          <span>↓</span>
        </a>
      </div>
    </div>

    <div class="mt-20 lg:mt-28 grid grid-cols-2 lg:grid-cols-4 gap-y-8 gap-x-6 reveal" style="--reveal-delay: 550ms">
      <div class="border-l border-border-strong pl-4">
        <div class="label mb-2">МЕТОД</div>
        <div class="font-mono text-[13px] text-text">ОТКРЫТЫЙ ПРОТОКОЛ</div>
      </div>
      <div class="border-l border-border-strong pl-4">
        <div class="label mb-2">СЕЗОН</div>
        <div class="font-mono text-[13px] text-text">2026 / БАЛКОН</div>
      </div>
      <div class="border-l border-border-strong pl-4">
        <div class="label mb-2">КУЛЬТУРЫ</div>
        <div class="font-mono text-[13px] text-text">КАРТОФЕЛЬ · КЛУБНИКА</div>
      </div>
      <div class="border-l border-border-strong pl-4">
        <div class="label mb-2">АВТОР</div>
        <div class="font-mono text-[13px] text-text">КУЛИБИН</div>
      </div>
    </div>

  </div>

  <div class="absolute hidden lg:block top-32 right-10 text-text-muted">
    <svg width="120" height="120" viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="0.5">
      <circle cx="60" cy="60" r="58"/>
      <circle cx="60" cy="60" r="40"/>
      <circle cx="60" cy="60" r="22"/>
      <circle cx="60" cy="60" r="2" fill="currentColor"/>
      <line x1="0" y1="60" x2="120" y2="60"/>
      <line x1="60" y1="0" x2="60" y2="120"/>
    </svg>
  </div>
</section>
